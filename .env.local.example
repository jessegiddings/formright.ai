# Anthropic (for chat widget)
ANTHROPIC_API_KEY=your_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

# Email (optional at launch — add in Phase 2)
RESEND_API_KEY=your_key_here

# App
NEXT_PUBLIC_APP_URL=https://formright.ai
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# PostHog (optional — analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Analytics dashboard
ANALYTICS_SECRET=your_secret_key_here

# Google Ads — affiliate click conversion (optional, activates click tracking).
# Set this once you create an "Affiliate Click" conversion action in Google Ads.
# Format: AW-XXXXXXXXX/YYYYYYYYYY
# If unset, affiliate click conversions are a silent no-op (no fake data fires).
NEXT_PUBLIC_GADS_AFFILIATE_CONVERSION=

# Affiliate tracking links — override defaults without a code deploy.
# Set these in Vercel as each program approves.
NEXT_PUBLIC_ZENBUSINESS_LINK=
NEXT_PUBLIC_LEGALZOOM_LINK=
NEXT_PUBLIC_NORTHWEST_LINK=
NEXT_PUBLIC_BIZEE_LINK=
NEXT_PUBLIC_TAILORBRANDS_LINK=
NEXT_PUBLIC_ROCKETLAWYER_LINK=
